# overrideable results dir
RESULTSDIR ?= results_x_rs
# overrideable plots dir
PLOTSDIR ?= plots_x_rs
# overrideable tikz dir
TIKZDIR ?= tikz_x_rs


# range of read sizes to test for throughput testing
P26_T_READ_SIZES ?= 1,4,8,16,32,64,128,256,512,1024,2048,4096,8192
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# spiffstp is a special rule below
BENCH_FSS ?= lfs3 lfs3nb lfs2 spiffs spiffstp yaffs2
# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# extra spiffstp config
U_spiffstp = SPIFFSTP
N_spiffstp = 40
I_spiffstp = 6
ifdef LIGHT
C_spiffstp = \#da8bc3bf # pink
else
C_spiffstp = \#da8bc3bf # pink
endif
F_spiffstp = x # small x
BENCH_SPIFFSTP_RUNNER ?= $(BENCH_SPIFFS_RUNNER)
BENCH_SPIFFSTP_FILTER ?= $(BENCH_SPIFFS_FILTER)
EMMC_SPIFFSTP_BLOCK_SIZE ?= $(EMMC_SPIFFS_BLOCK_SIZE)
NOR_SPIFFSTP_BLOCK_SIZE  ?= $(NOR_SPIFFS_BLOCK_SIZE)
NAND_SPIFFSTP_BLOCK_SIZE ?= $(NAND_SPIFFS_BLOCK_SIZE)

# use our bench rules
BENCH_RULES ?= \
	bench-p26-x-rs
# use our plot rules
PLOT_RULES ?= \
	plot-p26-x-rs
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-x-rs

# default Makefile does most of the work
include Makefile



## Run p26 read size benchmarks
.PHONY: bench-p26-x-rs
bench-p26-x-rs: \
		bench-p26-x-rs-logging

## Run p26 read size logging benchmarks
.PHONY: bench-p26-x-rs-logging
bench-p26-x-rs-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_rs_logging.$(fs).$(sim).csv))


# p26 read size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - read sizes
#
define BENCH_P26_T_X_RS_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$$(shell python -c '$\
			print(",".join(str(x) for x in [$(or $5,$(P26_T_READ_SIZES))] $\
				if x < $($(U_$4)_ERASE_SIZE)))') \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		$(if $(filter spiffstp,$3), -DSPAGE_TIGHT=1) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 read size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_X_RS_RULE,$\
				$(RESULTSDIR)/bench_p26_x_rs_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 read size benchmarks
.PHONY: plot-p26-x-rs
plot-p26-x-rs: \
		plot-p26-x-rs-nor \
		plot-p26-x-rs-nand

## Plot p26 read size nor benchmarks
.PHONY: plot-p26-x-rs-nor
plot-p26-x-rs-nor: \
		$(PLOTSDIR)/bench_p26_x_rs_nor.svg

## Plot p26 read size nand benchmarks
.PHONY: plot-p26-x-rs-nand
plot-p26-x-rs-nand: \
		$(PLOTSDIR)/bench_p26_x_rs_nand.svg



# p26 read sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_X_RS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='simulated throughput (bounded ram)' \
			-Dm=write+tsim \
			-DFS=$$(shell python -c 'print(",".join($\
				"$(foreach fs,$(filter-out yaffs2,$(BENCH_FSS)),$\
					$(N_$(fs)))".split()))') \
 			--y2 --yunits=B/s \
			-W0.5" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 read size plot rules
$(eval $(call PLOT_P26_X_RS_RULE,$\
		$(PLOTSDIR)/bench_p26_x_rs_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_x_rs_logging.$(fs).%.tsim.csv \
			$(RESULTSDIR)/bench_p26_x_rs_logging.$(fs).%.ram.csv),$\
		"read sizes - $$* - logging - simulated throughput",$\
		READ_SIZE,$\
		$(P26_T_READ_SIZES),$\
		--xlabel="read size"))




## Generate read size tikz results
.PHONY: tikz-p26-x-rs
tikz-p26-x-rs: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, logging, \
					$(TIKZDIR)/tikz_p26_x_rs_$(bench).$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, logging, \
					$(TIKZDIR)/tikz_p26_x_rs_ram_$(bench).$(fs).$(sim).csv)))

# tikz read size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_RS_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bREAD_SIZE \
		-Si=READ_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, logging, \
			$(eval $(call TIKZ_T_X_RS_RULE,$\
				$(TIKZDIR)/tikz_p26_x_rs_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_rs_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz read size ram rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_RS_RAM_RULE
$1: $(BENCH_$(U_$3)_RUNNER) $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=stack \
			-fdata="$$$$( \
				./scripts/data.py $$< -bfunction -o- \
					| $(BENCH_$(U_$3)_FILTER) \
					| ./scripts/csv.py - -fdata_size --total)" \
			-fstack=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=heap \
			-fheap=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bREAD_SIZE \
		-Si=READ_SIZE \
		-fdata \
		-fstack \
		-fheap \
		-fram=data+stack+heap \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, logging, \
			$(eval $(call TIKZ_T_X_RS_RAM_RULE,$\
				$(TIKZDIR)/tikz_p26_x_rs_ram_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_rs_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

