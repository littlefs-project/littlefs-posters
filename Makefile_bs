# overrideable results dir, default to ./results_1M
RESULTSDIR ?= results_bs
# overrideable plots dir, defaults ./plots_1M
PLOTSDIR ?= plots_bs


# range of erase sizes to test for throughput testing
P26_T_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072
P26_T_BLOCK_SIZES_1M ?= 4096,8192,16384,32768,65536,131072,$\
		262144,524288,1048576

# 1MiB sizes
DISK_SIZE_1M ?= 268435456
P26_T_SIZE_1M ?= 1048576


# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_P26_RULES ?= \
	bench-p26-wt-bs \
	bench-p26-wt-bs-1M
# use our plot rules
PLOT_P26_RULES ?= \
	plot-p26-wt-bs \
	plot-p26-wt-bs-1M

