# p26 block sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - measurement
# $7 - extra plotmpl.py flags
#
define PLOT_P26_BS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		-Dm=$6 \
		--subplot=" \
			-DERASE_SIZE=$(NOR_ERASE_SIZE) \
			--title=nor" \
		--subplot-right=" \
			-DERASE_SIZE=$(NAND_ERASE_SIZE) \
			--title=nand \
			-W0.5" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$7 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 block size plot rules
$(eval $(call PLOT_P26_BS_RULE,$\
		$(PLOTSDIR)/bench_p26_bs_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
				$(RESULTSDIR)/bench_p26_bs_%.$(fs).$(sim).tsim.csv)),$\
		"$$* file writes - block sizes - simulated throughput",$\
		BLOCK_SIZE,$\
		$(P26_T_BLOCK_SIZES),$\
		write+tsim,$\
		--xlabel="block size" --y2 --yunits=B/s))

$(eval $(call PLOT_P26_BS_RULE,$\
		$(PLOTSDIR)/bench_p26_bs_usage_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
				$(RESULTSDIR)/bench_p26_bs_%.$(fs).$(sim).csv)),$\
		"$$* file writes - block sizes - disk usage",$\
		BLOCK_SIZE,$\
		$(P26_T_BLOCK_SIZES),$\
		usage,$\
		--xlabel="block size" --y2 --yunits=B))

$(eval $(call PLOT_P26_BS_RULE,$\
		$(PLOTSDIR)/bench_p26_bs_ram_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
				$(RESULTSDIR)/bench_p26_bs_%.$(fs).$(sim).ram.csv)),$\
		"$$* file writes - block sizes - RAM usage",$\
		BLOCK_SIZE,$\
		$(P26_T_BLOCK_SIZES),$\
		ram,$\
		--xlabel="block size" --y2 --yunits=B))


