# overrideable results dir
RESULTSDIR ?= results_x_ds
# overrideable plots dir
PLOTSDIR ?= plots_x_ds


# range of disk sizes to test for throughput testing
P26_T_DISK_SIZES ?= 8388608,16777216,33554432,67108864,134217728,268435456,$\
		536870912,1073741824,2147483648,4294967296,8589934592
# prevent parallel benches because of how big disk is
DISK_BIG = 1
# some other tweaks
# 1MiB target
#P26_T_SIZE ?= 1048576
P26_T_SIZE ?= 32768

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-x-ds
# use our plot rules
PLOT_RULES ?= \
	plot-p26-x-ds

# default Makefile does most of the work
include Makefile



## Run p26 disk size benchmarks
.PHONY: bench-p26-x-ds
bench-p26-x-ds: \
		bench-p26-x-ds-logging

## Run p26 disk size linear benchmarks
.PHONY: bench-p26-x-ds-linear
bench-p26-x-ds-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_ds_linear.$(fs).$(sim).csv))

## Run p26 disk size random benchmarks
.PHONY: bench-p26-x-ds-random
bench-p26-x-ds-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_ds_random.$(fs).$(sim).csv))

## Run p26 disk size many benchmarks
.PHONY: bench-p26-x-ds-many
bench-p26-x-ds-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_ds_many.$(fs).$(sim).csv))

## Run p26 disk size logging benchmarks
.PHONY: bench-p26-x-ds-logging
bench-p26-x-ds-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_ds_logging.$(fs).$(sim).csv))


# p26 disk size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - disk sizes
#
define BENCH_P26_T_X_DS_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(or $5,$(P26_T_DISK_SIZES)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 disk size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_X_DS_RULE,$\
				$(RESULTSDIR)/bench_p26_x_ds_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 disk size benchmarks
.PHONY: plot-p26-x-ds
plot-p26-x-ds: \
		plot-p26-x-ds-nor \
		plot-p26-x-ds-nand

## Plot p26 disk size nor benchmarks
.PHONY: plot-p26-x-ds-nor
plot-p26-x-ds-nor: \
		$(PLOTSDIR)/bench_p26_x_ds_nor.svg

## Plot p26 disk size nand benchmarks
.PHONY: plot-p26-x-ds-nand
plot-p26-x-ds-nand: \
		$(PLOTSDIR)/bench_p26_x_ds_nand.svg



# p26 disk sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_X_DS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='simulated throughput (bounded ram)' \
			-Dm=write+tsim \
			-DFS=$$(shell python -c 'print(",".join($\
				"$(foreach fs,$(filter-out yaffs2,$(BENCH_FSS)),$\
					$(N_$(fs)))".split()))') \
 			--y2 --yunits=B/s \
			-W0.5" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 disk size plot rules
$(eval $(call PLOT_P26_X_DS_RULE,$\
		$(PLOTSDIR)/bench_p26_x_ds_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_x_ds_logging.$(fs).%.tsim.csv \
			$(RESULTSDIR)/bench_p26_x_ds_logging.$(fs).%.ram.csv),$\
		"disk sizes - $$* - logging - simulated throughput",$\
		DISK_SIZE,$\
		$(P26_T_DISK_SIZES),$\
		--xlabel="disk size"))


