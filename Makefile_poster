# overrideable results dir
RESULTSDIR ?= results_poster
# overrideable plots dir
PLOTSDIR ?= plots_poster
# overrideable tikz dir
TIKZDIR ?= tikz_poster


# give us more space for activities
DISK_SIZE ?= 134217728 # 128 MiB

# how many entries to test?
#BENCH_RBYD_N ?= 4096
BENCH_RBYD_N ?= 8192
#BENCH_BTREE_N ?= 4096
BENCH_BTREE_N ?= 8192
# how big a file to simulate?
#BENCH_WT_SIZE ?= 1048576 # 1 MiB
BENCH_WT_SIZE ?= 2097152 # 2 MiB
#BENCH_WT_SIZE ?= 16777216 # 16 MiB
# how big a chunk to write?
BENCH_WT_CHUNK ?= 64

# how many samples?
ifdef PRECISE
SAMPLES ?= 16
else
SAMPLES ?= 1
endif
# how long to simulate?
ifdef PRECISE
SIM_TIME ?= 3600000000000 # 1 hour
else
SIM_TIME ?= 600000000000 # 10 minutes
endif

# stride of results to filter during tikz processing
COMB ?= 1

# block sizes for btree benchmarks
BENCH_BTREE_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576
# block sizes for write-throughput benchmarks
BENCH_WT_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576

# enable debug to make sure benches work, otherwise asserts are disabled
#DEBUG ?= 1


# we only care about littlefs3+nogbmap and littlefs2
BENCH_FSS ?= lfs3nb lfs2
# we only care about NOR for now
BENCH_SIMS ?= nor


# override bench rules
BENCH_RULES ?= \
	bench-p26-poster-rbyd \
	bench-p26-poster-btree \
	bench-p26-poster-wt
# override plot rules
PLOT_RULES ?= \
	plot-p26-poster-rbyd \
	plot-p26-poster-btree \
	plot-p26-poster-wt
# override tikz rules
TIKZ_RULES ?= \
	tikz-p26-poster-rbyd \
	tikz-p26-poster-btree \
	tikz-p26-poster-wt

# default Makefile does most of the work
include Makefile


## Run rbyd benchmarks
.PHONY: bench-p26-poster-rbyd
bench-p26-poster-rbyd: $(RESULTSDIR)/bench_p26_poster_rbyd.csv

$(RESULTSDIR)/bench_p26_poster_rbyd.csv: $(BENCH_LFS3NB_RUNNER)
	$(strip ./scripts/bench.py -R$< -B bench_p26_rbyd \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DFS=$(N_lfs3) \
		-DSEED="range($(SAMPLES))" \
		-DN=$(BENCH_RBYD_N) \
		-DREAD_TIME=$(NOR_READ_TIME) \
		-DPROG_TIME=$(NOR_PROG_TIME) \
		-DERASE_TIME=$(NOR_ERASE_TIME) \
		-o$@)

## Run btree benchmarks
.PHONY: bench-p26-poster-btree
bench-p26-poster-btree: $(RESULTSDIR)/bench_p26_poster_btree.csv

$(RESULTSDIR)/bench_p26_poster_btree.csv: $(BENCH_LFS3NB_RUNNER)
	$(strip ./scripts/bench.py -R$< -B bench_p26_btree \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DFS=$(N_lfs3) \
		-DSEED="range($(SAMPLES))" \
		-DN=$(BENCH_BTREE_N) \
		-DREAD_TIME=$(NOR_READ_TIME) \
		-DPROG_TIME=$(NOR_PROG_TIME) \
		-DERASE_TIME=$(NOR_ERASE_TIME) \
		-DORDER=2 \
		-DBLOCK_SIZE="$(BENCH_BTREE_BLOCK_SIZES)" \
		-o$@)

## Run write-throughput benchmarks
.PHONY: bench-p26-poster-wt
bench-p26-poster-wt: \
		$(foreach fs,$(BENCH_FSS),\
			$(RESULTSDIR)/bench_p26_poster_wt.$(fs).csv)

# $1 - target
# $2 - fs type/version
# $3 - block sizes
define BENCH_P26_POSTER_WT_RULE
$1: $(BENCH_$(U_$2)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B \
		bench_p26_wt_linear \
		bench_p26_wt_random \
		bench_p26_wt_logging \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DFS=$(N_$2) \
		-DSEED="range($(SAMPLES))" \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(BENCH_WT_SIZE) \
		-DCHUNK=$(BENCH_WT_CHUNK) \
		-DSIM_TIME=$(SIM_TIME) \
		-DREAD_TIME=$(NOR_READ_TIME) \
		-DPROG_TIME=$(NOR_PROG_TIME) \
		-DERASE_TIME=$(NOR_ERASE_TIME) \
		-DBLOCK_SIZE="$(or $3,$(BENCH_WT_BLOCK_SIZES))" \
		-o$$@)
endef

$(foreach fs,$(BENCH_FSS),$\
	$(eval $(call BENCH_P26_POSTER_WT_RULE,$\
		$(RESULTSDIR)/bench_p26_poster_wt.$(fs).csv,$\
		$(fs))))


## Plot rbyd benchmarks
.PHONY: plot-p26-poster-rbyd
plot-p26-poster-rbyd: $(PLOTSDIR)/bench_p26_poster_rbyd.svg

$(PLOTSDIR)/bench_p26_poster_rbyd.svg: \
		$(RESULTSDIR)/bench_p26_poster_rbyd.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_rbyd.per.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_rbyd.sim.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_rbyd.sim.per.avg.csv
	$(strip ./scripts/plotmpl.py \
		<(./scripts/csv.py $^ \
			-fbench_readed_avg \
			-fbench_readed_bnd=bench_readed_max \
			-o-) \
		<(./scripts/csv.py $^ \
			-Dbench_readed_avg='*' \
			-fbench_readed_bnd=bench_readed_min \
			-o-) \
		-W1500 -H350 \
		--title='rbyd operations' \
		-bORDER \
		-xn \
		-ybench_readed_avg \
		-ybench_readed_bnd \
		--yunits=s \
		--legend \
		-L0,bench_readed_avg=inorder \
		-L1,bench_readed_avg=reversed \
		-L2,bench_readed_avg=random \
		-L0,bench_readed_bnd= \
		-L1,bench_readed_bnd= \
		-L2,bench_readed_bnd= \
		-C0,bench_readed_avg=$(C_lfs3) \
		-C1,bench_readed_avg=$(C_lfs3nb) \
		-C2,bench_readed_avg=$(C_lfs2) \
		-C0,bench_readed_bnd=$(C_lfs3:bf=1f) \
		-C1,bench_readed_bnd=$(C_lfs3nb:bf=1f) \
		-C2,bench_readed_bnd=$(C_lfs2:bf=1f) \
		--subplot=" \
			-Dm='create+sim' \
			--title='create'" \
		--subplot-right=" \
			-Dm='delete+sim' \
			--title='delete' \
			-W0.5" \
		--subplot-right=" \
			-Dm='fetch+sim+per' \
			--title='fetch (per attr)' \
			-W0.33" \
		--subplot-right=" \
			-Dm='lookup+sim' \
			--title='lookup' \
			-W0.25" \
		--subplot-right=" \
			-Dm='usage+per' \
			--title='usage (per attr)' \
			--y2 --yunits=B \
			-W0.2" \
		$(PLOTFLAGS) \
		-o$@)

## Plot btree benchmarks
.PHONY: plot-p26-poster-btree
plot-p26-poster-btree: $(PLOTSDIR)/bench_p26_poster_btree.svg

$(PLOTSDIR)/bench_p26_poster_btree.svg: \
		$(RESULTSDIR)/bench_p26_poster_btree.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_btree.per.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_btree.sim.avg.csv \
		$(RESULTSDIR)/bench_p26_poster_btree.sim.amor.avg.csv
	$(strip ./scripts/plotmpl.py \
		<(./scripts/csv.py $^ \
			-fbench_readed_avg \
			-fbench_readed_bnd=bench_readed_max \
			-o-) \
		<(./scripts/csv.py $^ \
			-Dbench_readed_avg='*' \
			-fbench_readed_bnd=bench_readed_min \
			-o-) \
		-W1500 -H350 \
		--title='btree operations' \
		-bBLOCK_SIZE \
		-xn \
		-ybench_readed_avg \
		-ybench_readed_bnd \
		--yunits=s \
		--legend \
		$(foreach bs,$(subst $(,), ,$(BENCH_BTREE_BLOCK_SIZES)),$\
			-L'$(bs),bench_readed_avg=$(bs)' \
			-L'$(bs),bench_readed_bnd=' \
			-C'$(bs),bench_readed_avg=$(C_lfs3)' \
			-C'$(bs),bench_readed_bnd=$(C_lfs3:bf=1f)') \
		--subplot=" \
			-Dm='commit+sim' \
			--title='commit' \
			$(if, --ylim-ratio=0.01)" \
		--subplot-right=" \
			-Dm='commit+sim+amor' \
			--title='commit (amortized)' \
			$(if, --ylim-ratio=0.01) $(if, --ylim-ratio=0.98) \
			-W0.5" \
		--subplot-right=" \
			-Dm='lookup+sim' \
			--title='lookup' \
			-W0.33" \
		--subplot-right=" \
			-Dm='usage+per' \
			--title='usage (per attr)' \
			--y2 --yunits=B \
			$(if, --ylim-ratio=0.01) $(if, --ylim-ratio=0.98) \
			-W0.25" \
		$(PLOTFLAGS) \
		-o$@)

## Plot write-throughput benchmarks
.PHONY: plot-p26-poster-wt
plot-p26-poster-wt: $(PLOTSDIR)/bench_p26_poster_wt.svg

$(PLOTSDIR)/bench_p26_poster_wt.svg: \
		$(foreach fs, $(BENCH_FSS), \
			$(RESULTSDIR)/bench_p26_poster_wt.$(fs).tsim.csv)
	$(strip ./scripts/plotmpl.py $^ \
		-W1500 -H350 \
		--title='file write throughput' \
		-bFS \
		-xBLOCK_SIZE \
		-ybench_readed \
		-Dm=write+tsim \
		--subplot=" \
			-Dcase=bench_p26_wt_linear \
			--title=linear" \
		--subplot-right=" \
			-Dcase=bench_p26_wt_random \
			--title=random \
			-W0.5" \
		--subplot-right=" \
			-Dcase=bench_p26_wt_logging \
			--title=logging \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$(shell python -c $\
				'a=min([$(BENCH_WT_BLOCK_SIZES)]); print(a-a/4)'),$\
			$(shell python -c $\
				'b=max([$(BENCH_WT_BLOCK_SIZES)]); print(b+b/4)')" \
		--x2 --xunits=B \
		$(shell python -c '$\
			for n in [$(BENCH_WT_BLOCK_SIZES)]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		--xlabel='block size' \
		--y2 --yunits=B/s \
		$(PLOTFLAGS) \
		-o$@)


## Generate rbyd tikz results
.PHONY: tikz-p26-poster-rbyd
tikz-p26-poster-rbyd: \
		$(foreach order, 0 1 2,$\
			$(TIKZDIR)/tikz_p26_poster_rbyd.$(order).csv \
			$(TIKZDIR)/tikz_p26_poster_rbyd.$(order).comb.csv)

# $1 - target
# $2 - source
# $3 - order
define TIKZ_P26_POSTER_RBYD_RULE
$1: $2
	$$(strip ./scripts/csv.py $$^ \
		-DORDER=$3 \
		-Dm=create+sim \
		-DSEED=0 \
		-bbench=create \
		-bORDER \
		-bn \
		-Si=n \
		-ft=bench_readed \
		-o$$@)
endef

$(foreach order, 0 1 2,$\
	$(eval $(call TIKZ_P26_POSTER_RBYD_RULE,$\
		$(TIKZDIR)/tikz_p26_poster_rbyd.$(order).csv,$\
		$(RESULTSDIR)/bench_p26_poster_rbyd.sim.csv,$\
		$(order))))

# filter results
$(TIKZDIR)/%.comb.csv: $(TIKZDIR)/%.csv
	$(strip awk \
		-v n=$$(wc -l < $<) \
		'NR==1 || NR==2 || NR==n || NR % $(COMB) == 0' \
		$^ > $@)

## Generate btree tikz results
.PHONY: tikz-p26-poster-btree
tikz-p26-poster-btree: \
		$(foreach bs,$(subst $(,), ,$(BENCH_BTREE_BLOCK_SIZES)),$\
			$(TIKZDIR)/tikz_p26_poster_btree.$(bs).csv \
			$(TIKZDIR)/tikz_p26_poster_btree.$(bs).comb.csv)

# $1 - target
# $2 - source
# $3 - order
define TIKZ_P26_POSTER_BTREE_RULE
$1: $2
	$$(strip ./scripts/csv.py $$^ \
		-DORDER=2 \
		-DBLOCK_SIZE=$3 \
		-Dm=commit+sim+amor \
		-bbench=commit \
		-bBLOCK_SIZE \
		-bn \
		-Si=n \
		-ft=bench_readed_avg \
		-o$$@)
endef

$(foreach bs,$(subst $(,), ,$(BENCH_BTREE_BLOCK_SIZES)),$\
	$(eval $(call TIKZ_P26_POSTER_BTREE_RULE,$\
		$(TIKZDIR)/tikz_p26_poster_btree.$(bs).csv,$\
		$(RESULTSDIR)/bench_p26_poster_btree.sim.amor.avg.csv,$\
		$(bs))))

## Generate write-throughput tikz results
.PHONY: tikz-p26-poster-wt
tikz-p26-poster-wt: \
		$(foreach fs,$(BENCH_FSS),$\
			$(foreach bench,linear random logging,$\
				$(TIKZDIR)/tikz_p26_poster_wt.$(fs).$(bench).csv))

# $1 - target
# $2 - source
# $3 - fs
# $4 - bench
define TIKZ_P26_POSTER_WT_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-Dcase=bench_p26_wt_$4 \
		-Dm=write,read \
		-bfs=$3 \
		-bbench=$4 \
		-bBLOCK_SIZE \
		-Si=BLOCK_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs,$(BENCH_FSS),$\
	$(foreach bench,linear random logging,$\
		$(eval $(call TIKZ_P26_POSTER_WT_RULE,$\
			$(TIKZDIR)/tikz_p26_poster_wt.$(fs).$(bench).csv,$\
			$(RESULTSDIR)/bench_p26_poster_wt.$(fs).csv,$\
			$(fs),$\
			$(bench)))))

