# overrideable results dir
RESULTSDIR ?= results_y_bt
# overrideable plots dir
PLOTSDIR ?= plots_y_bt
# overrideable tikz dir
TIKZDIR ?= tikz_y_bt


# range of erase sizes to test for throughput testing
# note 1024 = 128MiB/128KiB (NAND)
# note 32768 = 128MiB/4KiB (NOR)
P26_T_BMAP_SCAN_THRESHS ?= 0,1,2,4,8,16,32,64,128,256,512,1024
# lookahead size is also interesting
# note the default was 16B (128 bits/blocks)
P26_T_LOOKAHEAD_SIZE ?= 16
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# this only makes sense for littlefs3
BENCH_FSS ?= lfs3 lfs3nb
# we mostly care about NAND, but NOR has higher block counts
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-y-bt
# use our plot rules
PLOT_RULES ?= \
	plot-p26-y-bt
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-y-bt

# default Makefile does most of the work
include Makefile



## Run p26 bmap scan thresh benchmarks
.PHONY: bench-p26-y-bt
bench-p26-y-bt: \
		bench-p26-y-bt-linear \
		bench-p26-y-bt-random \
		bench-p26-y-bt-many \
		bench-p26-y-bt-logging

## Run p26 bmap scan thresh linear benchmarks
.PHONY: bench-p26-y-bt-linear
bench-p26-y-bt-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_bt_linear.$(fs).$(sim).csv))

## Run p26 bmap scan thresh random benchmarks
.PHONY: bench-p26-y-bt-random
bench-p26-y-bt-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_bt_random.$(fs).$(sim).csv))

## Run p26 bmap scan thresh many benchmarks
.PHONY: bench-p26-y-bt-many
bench-p26-y-bt-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_bt_many.$(fs).$(sim).csv))

## Run p26 bmap scan thresh logging benchmarks
.PHONY: bench-p26-y-bt-logging
bench-p26-y-bt-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_bt_logging.$(fs).$(sim).csv))


# p26 bmap scan thresh bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - bmap scan threshes
# $6 - lookahead size
#
define BENCH_P26_T_Y_BT_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DBMAP_SCAN_THRESH=$(or $5,$(P26_T_BMAP_SCAN_THRESHS)) \
		-DLOOKAHEAD_SIZE=$(or $6,$(P26_T_LOOKAHEAD_SIZE)) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 bmap scan thresh bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_Y_BT_RULE,$\
				$(RESULTSDIR)/bench_p26_y_bt_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



