# overrideable results dir
RESULTSDIR ?= results_et
# overrideable plots dir
PLOTSDIR ?= plots_et


# range of erase timings to test for throughput testing
P26_T_ERASE_TIMES ?= 10,30,100,300,1000,3000,10000,30000

# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-et
# use our plot rules
PLOT_RULES ?= \
	plot-p26-et

# default Makefile does most of the work
include Makefile



## Run p26 erase timing benchmarks
.PHONY: bench-p26-et
bench-p26-et: \
		bench-p26-et-linear \
		bench-p26-et-random \
		bench-p26-et-many \
		bench-p26-et-logging

## Run p26 erase timing linear benchmarks
.PHONY: bench-p26-et-linear
bench-p26-et-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_et_linear.$(fs).$(sim).csv))

## Run p26 erase timing random benchmarks
.PHONY: bench-p26-et-random
bench-p26-et-random: \
