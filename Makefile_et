## Run p26 erase timing logging benchmarks
.PHONY: bench-p26-et-logging
bench-p26-et-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_et_logging.$(fs).$(sim).csv))


# p26 erase timing bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - erase timings
#
define BENCH_P26_T_ET_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 erase timing bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_ET_RULE,$\
				$(RESULTSDIR)/bench_p26_et_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))


# simulated throughput results
#
# note we first sum n/readed/proged/erased
$(RESULTSDIR)/bench_%.etsim.csv: $(RESULTSDIR)/bench_%.csv
	-$(strip ./scripts/csv.py \
		$(foreach et,$(subst $(,), ,$(P26_T_ERASE_TIMES)),$\
			<(./scripts/csv.py $^ \
				-BERASE_TIME=$(et) \
				-fn \
				-fbench_readed \
				-fbench_proged \
				-fbench_erased \
				-Dbench_creaded='*' \
				-Dbench_cproged='*' \
				-Dbench_cerased='*' \
				-o-)) \
		-Bm='%(m)s+tsim' \
		-BERASE_TIME \
		-fn \
		-fbench_readed=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fbench_proged=0 \
		-fbench_erased=0 \
		-o$@)



