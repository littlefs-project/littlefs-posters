			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_et_random.$(fs).$(sim).csv))

## Run p26 erase timing many benchmarks
.PHONY: bench-p26-et-many
bench-p26-et-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
