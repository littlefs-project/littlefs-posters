# overrideable results dir
RESULTSDIR ?= results_x_n_1G
# overrideable plots dir
PLOTSDIR ?= plots_x_n_1G
# overrideable tikz dir
TIKZDIR ?= tikz_x_n_1G


# give us more space for activities
DISK_SIZE ?= 8589934592 # 8 GiB
# prevent parallel benches because of how big disk is
DISK_BIG = 1

# 64B -> 1GiB
P26_T_SIZES ?= $\
	64,128,256,512,$\
	1024,2048,4096,8192,16384,32768,$\
		65536,131072,262144,524288,$\
	1048576,2097152,4194304,8388608,16777216,33554432,$\
		67108864,134217728,268435456,536870912,1073741824

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 86400000000000 # 1 day
else
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
endif

# we DO test all filesystems, this is the main difference between
# other 1G benchmarks, however we only bench logging
#
# this avoids linked-list scaling issues with yaffs2

# also lfs3nf as defined below
BENCH_FSS ?= lfs3 lfs3nb lfs3nf lfs2 spiffs yaffs2
# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# extra lfs3nf config
U_lfs3nf = LFS3NF
N_lfs3nf = 31
I_lfs3nf = 6
ifdef LIGHT
C_lfs3nf = \#da8bc3bf # pink
else
C_lfs3nf = \#da8bc3bf # pink
endif
F_lfs3nf = x # small x
BENCH_LFS3NF_RUNNER ?= $(BENCH_LFS3_RUNNER)
BENCH_LFS3NF_FILTER ?= $(BENCH_LFS3_FILTER)
EMMC_LFS3NF_BLOCK_SIZE ?= $(EMMC_LFS3_BLOCK_SIZE)
NOR_LFS3NF_BLOCK_SIZE  ?= $(NOR_LFS3_BLOCK_SIZE)
NAND_LFS3NF_BLOCK_SIZE ?= $(NAND_LFS3_BLOCK_SIZE)

# use our bench rules
BENCH_RULES ?= \
	bench-p26-x-n-1G
# use our plot rules
PLOT_RULES ?= \
	plot-p26-x-n-1G
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-x-n-1G

# default Makefile does most of the work
include Makefile



## Run p26 target size benchmarks
.PHONY: bench-p26-x-n-1G
bench-p26-x-n-1G: \
		bench-p26-x-n-1G-logging

## Run p26 target size logging benchmarks
.PHONY: bench-p26-x-n-1G-logging
bench-p26-x-n-1G-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_n_1G_logging.$(fs).$(sim).csv))


# p26 target size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - target sizes
#
define BENCH_P26_T_X_N_1G_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(or $5,$(P26_T_SIZES)) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		$(if $(filter lfs3nf,$3),-DNO_FRUNCATE=1) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 target size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_X_N_1G_RULE,$\
				$(RESULTSDIR)/bench_p26_x_n_1G_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 target size benchmarks
.PHONY: plot-p26-x-n-1G
plot-p26-x-n-1G: \
		plot-p26-x-n-1G-nor \
		plot-p26-x-n-1G-nand

## Plot p26 target size nor benchmarks
.PHONY: plot-p26-x-n-1G-nor
plot-p26-x-n-1G-nor: \
		$(PLOTSDIR)/bench_p26_x_n_1G_nor.svg

## Plot p26 target size nand benchmarks
.PHONY: plot-p26-x-n-1G-nand
plot-p26-x-n-1G-nand: \
		$(PLOTSDIR)/bench_p26_x_n_1G_nand.svg



# p26 target sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_X_N_1G_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='simulated throughput (bounded ram)' \
			-Dm=write+tsim \
			-DFS=$$(shell python -c 'print(",".join($\
				"$(foreach fs,$(filter-out yaffs2,$(BENCH_FSS)),$\
					$(N_$(fs)))".split()))') \
 			--y2 --yunits=B/s \
			-W0.5" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 target size plot rules
$(eval $(call PLOT_P26_X_N_1G_RULE,$\
		$(PLOTSDIR)/bench_p26_x_n_1G_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_x_n_1G_logging.$(fs).%.tsim.csv \
			$(RESULTSDIR)/bench_p26_x_n_1G_logging.$(fs).%.ram.csv),$\
		"target sizes - $$* - logging - simulated throughput",$\
		SIZE,$\
		$(P26_T_SIZES),$\
		--xlabel="target size"))




## Generate target size tikz results
.PHONY: tikz-p26-x-n-1G
tikz-p26-x-n-1G: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, logging, \
					$(TIKZDIR)/tikz_p26_x_n_1G_$(bench).$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, logging, \
					$(TIKZDIR)/tikz_p26_x_n_1G_ram_$(bench).$(fs).$(sim).csv)))

# tikz target size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_N_1G_RULE
$1: $2
	-$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bSIZE \
		-Si=SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, logging, \
			$(eval $(call TIKZ_T_X_N_1G_RULE,$\
				$(TIKZDIR)/tikz_p26_x_n_1G_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_n_1G_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz target size ram rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_N_1G_RAM_RULE
$1: $(BENCH_$(U_$3)_RUNNER) $2
	-$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=stack \
			-fdata="$$$$( \
				./scripts/data.py $$< -bfunction -o- \
					| $(BENCH_$(U_$3)_FILTER) \
					| ./scripts/csv.py - -fdata_size --total)" \
			-fstack=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=heap \
			-fheap=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bSIZE \
		-Si=SIZE \
		-fdata \
		-fstack \
		-fheap \
		-fram=data+stack+heap \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, logging, \
			$(eval $(call TIKZ_T_X_N_1G_RAM_RULE,$\
				$(TIKZDIR)/tikz_p26_x_n_1G_ram_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_n_1G_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

