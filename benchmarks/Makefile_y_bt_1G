# overrideable results dir
RESULTSDIR ?= results_y_bt_1G
# overrideable plots dir
PLOTSDIR ?= plots_y_bt_1G
# overrideable tikz dir
TIKZDIR ?= tikz_y_bt_1G


# give us more space for activities
DISK_SIZE ?= 8589934592 # 8 GiB
# prevent parallel benches because of how big disk is
DISK_BIG = 1

# increase bench sizes to 1GiB
P26_T_SIZE ?= 1073741824 # 1GiB


# range of erase sizes to test for throughput testing
# note 65536 = 8GiB/128KiB (NAND)
# note 2097152 = 8GiB/4KiB (NOR)
P26_T_BMAP_SCAN_THRESHS ?= $\
	0,$\
	1,2,4,8,16,32,64,128,256,512,1024,$\
	2048,4096,8192,16384,32768,65536

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 86400000000000 # 1 day
else
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
SKIP_WARMUP ?= 1
endif



# let the 1M Makefile do most of the work
include Makefile_y_bt


