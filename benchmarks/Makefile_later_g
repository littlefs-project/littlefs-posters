# overrideable results dir
RESULTSDIR ?= results_later_g
# overrideable plots dir
PLOTSDIR ?= plots_later_g
# overrideable tikz dir
TIKZDIR ?= tikz_later_g


# give us more space for activities
DISK_SIZE ?= 134217728 # 128 MiB

# how big a file to simulate?
#BENCH_SIZE ?= 1048576 # 1 MiB 
BENCH_SIZE ?= 2097152 # 2 MiB
# how big a chunk to write?
BENCH_CHUNK ?= 64

# read sizes to benchmark
BENCH_READ_SIZES ?= 1,2,4,8,16,32,64,128,256,512,1024,2048,4096 #,8192
# prog sizes to benchmark
BENCH_PROG_SIZES ?= 1,2,4,8,16,32,64,128,256,512,1024,2048,4096 #,8192
# block sizes to benchmark
BENCH_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
		262144,524288,1048576

# how long to simulate
ifdef PRECISE
SIM_TIME ?= 3600000000000 # 1 hour
else
#SIM_TIME ?= 600000000000 # 10 minutes
SIM_TIME ?= 60000000000 # 1 minute
endif

# include all filesystems and some variants
# focus littlefs3/2, but explore some different configurations
BENCH_FSS ?= lfs3 lfs3nb lfs3f lfs3nf lfs2
# use our fancy bus+buffer sim
BENCH_SIMS ?= nor nand
#BENCH_SIMPLE ?= 1

# enable debug to make sure benches work, otherwise asserts are disabled
#DEBUG ?= 1


# extra configuration
U_lfs3f = LFS3F
N_lfs3f = 31
I_lfs3f = 6
ifdef LIGHT
C_lfs3f = \#c44e52bf # red
else
C_lfs3f = \#c44e52bf # red
endif
F_lfs3f = H # hexagon
BENCH_LFS3F_RUNNER ?= $(BENCH_LFS3_RUNNER)
BENCH_LFS3F_FILTER ?= $(BENCH_LFS3_FILTER)

U_lfs3nf = LFS3F
N_lfs3nf = 32
I_lfs3nf = 7
ifdef LIGHT
C_lfs3nf = \#937860bf # brown
else
C_lfs3nf = \#debb9bbf # brown
endif
F_lfs3nf = p # pentagon
BENCH_LFS3NF_RUNNER ?= $(BENCH_LFS3_RUNNER)
BENCH_LFS3NF_FILTER ?= $(BENCH_LFS3_FILTER)


# use our bench rules
BENCH_RULES ?= \
	bench-p26-later-g-wt
# use our plot rules
PLOT_RULES ?= \
	plot-p26-later-g-wt
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-later-g-wt

# default Makefile does most of the work
include Makefile


## Run geometry wt benchmarks
.PHONY: bench-p26-later-g-wt
bench-p26-later-g-wt: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach g, rs ps bs, \
					$(RESULTSDIR)/bench_p26_later_g_wt.$(fs).$(sim).$(g).csv)))

# $1 - target
# $2 - fs type/version
# $3 - sim type
# $4 - bench flags
define BENCH_P26_LATER_G_WT_RULE
$1: $(BENCH_$(U_$2)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B bench_p26_wt \
		$(BENCHFLAGS) \
		-DFS=$(N_$2) \
		$(if $(filter lfs3f,$2),-DCRYSTAL_THRESH=-1) \
		$(if $(filter lfs3nf,$2),-DNO_FRUNCATE=1) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DDISK_GEOMETRY=$(N_$3) \
		$(if $(BENCH_SIMPLE),-DDISK_SIM=1) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(BENCH_SIZE) \
		-DCHUNK=$(BENCH_CHUNK) \
		-DSIM_TIME=$(SIM_TIME) \
		$4 \
		-o$$@)
endef

$(foreach fs,$(BENCH_FSS),$\
	$(foreach sim,$(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_LATER_G_WT_RULE,$\
			$(RESULTSDIR)/bench_p26_later_g_wt.$(fs).$(sim).rs.csv,$\
			$(fs),$\
			$(sim),$\
			-DREAD_SIZE=$(BENCH_READ_SIZES)))))

$(foreach fs,$(BENCH_FSS),$\
	$(foreach sim,$(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_LATER_G_WT_RULE,$\
			$(RESULTSDIR)/bench_p26_later_g_wt.$(fs).$(sim).ps.csv,$\
			$(fs),$\
			$(sim),$\
			-DPROG_SIZE=$(BENCH_PROG_SIZES)))))

$(foreach fs,$(BENCH_FSS),$\
	$(foreach sim,$(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_LATER_G_WT_RULE,$\
			$(RESULTSDIR)/bench_p26_later_g_wt.$(fs).$(sim).bs.csv,$\
			$(fs),$\
			$(sim),$\
			-DBLOCK_SIZE=$(BENCH_BLOCK_SIZES)))))


## Plot geometry wt benchmarks
.PHONY: plot-p26-later-g-wt
plot-p26-later-g-wt: \
		$(foreach sim, $(BENCH_SIMS), \
			$(PLOTSDIR)/bench_p26_later_g_wt.$(sim).svg)

$(PLOTSDIR)/bench_p26_later_g_wt.%.csv: \
		$(foreach g, rs ps bs, \
			$(RESULTSDIR)/bench_p26_later_g_wt.%.$(g).csv)
	$(strip ./scripts/csv.py \
		$(foreach g, rs ps bs, \
			<(./scripts/csv.py $(RESULTSDIR)/bench_p26_later_g_wt.$*.$(g).csv \
				-Dprobe=write \
				-bFS -bDISK_GEOMETRY -bcase -bg=$(g) \
				-bREAD_SIZE -bPROG_SIZE -bBLOCK_SIZE \
				-fbench_throughput=' \
					float(n) / max(float(bench_simtime)/1.0e9, 1.0e-9)' \
				-o-)) \
		-bFS -bDISK_GEOMETRY -bcase -bg \
		-bREAD_SIZE -bPROG_SIZE -bBLOCK_SIZE \
		-o$@)

$(PLOTSDIR)/bench_p26_later_g_wt.%.svg: \
		$(foreach fs, $(BENCH_FSS), \
			$(PLOTSDIR)/bench_p26_later_g_wt.$(fs).%.csv)
	$(strip ./scripts/plotmpl.py $^ \
		-W1150 -H475 $(filter, -W1150 -H350 $(filter,-W1500 -H350)) \
		--wpad=2 --hpad=2 \
		--title='simulated write throughput - $* - disk geometry' \
		-bFS \
		-ybench_throughput \
		--y2 --yunits=B/s \
		--subplot=" \
				-Dcase=bench_p26_wt_linear \
				-Dg=rs \
				-xREAD_SIZE \
				--xlog --x2 --xunits=B \
				-X\"$(shell python -c $\
						'a=min([$(BENCH_READ_SIZES)]); print(a-a/4)'),$\
					$(shell python -c $\
						'b=max([$(BENCH_READ_SIZES)]); print(b+b/4)')\" \
				--xticks=0 \
				$(shell python -c '$\
					for n in [$(BENCH_READ_SIZES)][::3]: $\
						print("--add-xticklabel=%d=\\\"%%(x)IB\\\"" % n)') \
				--title=sequential \
				--ylabel='read size%nthroughput' \
				--xlabel='read size' \
			--subplot-below=\" \
				-Dcase=bench_p26_wt_linear \
				-Dg=ps \
				-xPROG_SIZE \
