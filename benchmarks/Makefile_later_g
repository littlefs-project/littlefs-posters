						print("--add-xticklabel=%d=\\\"%%(x)IB\\\"" % n)') \
				--ylabel='prog size%nthroughput' \
				--xlabel='prog size'\" \
			--subplot-below=\" \
				-Dcase=bench_p26_wt_linear \
				-Dg=bs \
				-xBLOCK_SIZE \
