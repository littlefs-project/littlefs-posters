# overrideable results dir
RESULTSDIR ?= results_bs_1M
# overrideable plots dir
PLOTSDIR ?= plots_bs_1M


# give us more space for activities
DISK_SIZE ?= 134217728 # 128 MiB
# target size = 1 MiB
P26_T_SIZE ?= 1048576 # 1 MiB

# a larger disk also means we can test more block sizes
P26_T_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
  262144,524288,1048576

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif


# block size Makefile does most of the work
include Makefile_bs

