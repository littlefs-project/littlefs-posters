# overrideable results dir
RESULTSDIR ?= results_x_mr
# overrideable plots dir
PLOTSDIR ?= plots_x_mr
# overrideable tikz dir
TIKZDIR ?= tikz_x_mr


# range of file sizes to test for throughput testing
P26_T_FILE_SIZES ?= $\
	8,16,32,$\
	64,128,256,512,$\
	1024,2048,4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-x-mr
# use our plot rules
PLOT_RULES ?= \
	plot-p26-x-mr
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-x-mr

# default Makefile does most of the work
include Makefile



## Run p26 metadata ratio benchmarks
.PHONY: bench-p26-x-mr
bench-p26-x-mr: \
		bench-p26-x-mr-many

## Run p26 metadata ratio many benchmarks
.PHONY: bench-p26-x-mr-many
bench-p26-x-mr-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_x_mr_many.$(fs).$(sim).csv))


# p26 metadata ratio bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - file sizes
#
define BENCH_P26_T_X_MR_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DFILE_SIZE=$(or $5,$(P26_T_FILE_SIZES)) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 metadata ratio bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_X_MR_RULE,$\
				$(RESULTSDIR)/bench_p26_x_mr_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 metadata ratio benchmarks
.PHONY: plot-p26-x-mr
plot-p26-x-mr: \
		plot-p26-x-mr-nor \
		plot-p26-x-mr-nand

## Plot p26 metadata ratio nor benchmarks
.PHONY: plot-p26-x-mr-nor
plot-p26-x-mr-nor: \
		$(PLOTSDIR)/bench_p26_x_mr_nor.svg

## Plot p26 metadata ratio nand benchmarks
.PHONY: plot-p26-x-mr-nand
plot-p26-x-mr-nand: \
		$(PLOTSDIR)/bench_p26_x_mr_nand.svg



# p26 metadata ratios plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_X_MR_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='simulated throughput (bounded ram)' \
			-Dm=write+tsim \
			-DFS=$$(shell python -c 'print(",".join($\
				"$(foreach fs,$(filter-out yaffs2,$(BENCH_FSS)),$\
					$(N_$(fs)))".split()))') \
 			--y2 --yunits=B/s \
			-W0.5" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.33" \
		--subplot-right=" \
			--title='disk usage' \
			-Dm=usage \
 			--y2 --yunits=B \
			-W0.25" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5][::4]: $\
				print("--add-xticklabel=%d=\"%%(x)IB%%n(%d)\"" % ($\
					n, $(P26_T_SIZE)/n))') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 metadata ratio plot rules
$(eval $(call PLOT_P26_X_MR_RULE,$\
		$(PLOTSDIR)/bench_p26_x_mr_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_x_mr_many.$(fs).%.tsim.csv \
			$(RESULTSDIR)/bench_p26_x_mr_many.$(fs).%.ram.csv \
			$(RESULTSDIR)/bench_p26_x_mr_many.$(fs).%.csv),$\
		"metadata ratios - $$* - many - simulated throughput",$\
		FILE_SIZE,$\
		$(P26_T_FILE_SIZES),$\
		--xlabel="file size"))




## Generate metadata ratio tikz results
.PHONY: tikz-p26-x-mr
tikz-p26-x-mr: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, many, \
					$(TIKZDIR)/tikz_p26_x_mr_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, many, \
					$(TIKZDIR)/tikz_p26_x_mr_ram_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, many, \
					$(TIKZDIR)/tikz_p26_x_mr_usage_$(bench)$\
						.$(fs).$(sim).csv)))

# tikz metadata ratio rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_MR_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bFILE_SIZE \
		-Si=FILE_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, many, \
			$(eval $(call TIKZ_T_X_MR_RULE,$\
				$(TIKZDIR)/tikz_p26_x_mr_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_mr_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz metadata ratio ram rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_MR_RAM_RULE
$1: $(BENCH_$(U_$3)_RUNNER) $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=stack \
			-fdata="$$$$( \
				./scripts/data.py $$< -bfunction -o- \
					| $(BENCH_$(U_$3)_FILTER) \
					| ./scripts/csv.py - -fdata_size --total)" \
			-fstack=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=heap \
			-fheap=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bFILE_SIZE \
		-Si=FILE_SIZE \
		-fdata \
		-fstack \
		-fheap \
		-fram=data+stack+heap \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, many, \
			$(eval $(call TIKZ_T_X_MR_RAM_RULE,$\
				$(TIKZDIR)/tikz_p26_x_mr_ram_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_mr_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz metadata ratio disk usage rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_X_MR_USAGE_RULE
$1: $2
	$$(strip ./scripts/csv.py $$^ \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bFILE_SIZE \
		-Si=FILE_SIZE \
		-Dm=usage \
		-fusage=bench_readed \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, many, \
			$(eval $(call TIKZ_T_X_MR_USAGE_RULE,$\
				$(TIKZDIR)/tikz_p26_x_mr_usage_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_x_mr_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

