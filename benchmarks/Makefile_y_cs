# overrideable results dir
RESULTSDIR ?= results_y_cs
# overrideable plots dir
PLOTSDIR ?= plots_y_cs
# overrideable tikz dir
TIKZDIR ?= tikz_y_cs


# range of cache sizes to test for throughput testing
# the main difference between this and x_cs is we go _below_ the page
# size, but note littlefs still limits rcache/pcache to page size!
P26_T_CACHE_SIZES ?= 1,4,8,16,32,64,128,256,512,$\
	1024,2048,4096,8192,16384,32768
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# this only makes sense for littlefs3
BENCH_FSS ?= lfs3 lfs3nb
# we only care about NOR and NAND here
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-y-cs
# use our plot rules
PLOT_RULES ?= \
	plot-p26-y-cs
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-y-cs

# default Makefile does most of the work
include Makefile



## Run p26 cache size benchmarks
.PHONY: bench-p26-y-cs
bench-p26-y-cs: \
		bench-p26-y-cs-linear \
		bench-p26-y-cs-random \
		bench-p26-y-cs-many \
		bench-p26-y-cs-logging

## Run p26 cache size linear benchmarks
.PHONY: bench-p26-y-cs-linear
bench-p26-y-cs-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_cs_linear.$(fs).$(sim).csv))

## Run p26 cache size random benchmarks
.PHONY: bench-p26-y-cs-random
bench-p26-y-cs-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_cs_random.$(fs).$(sim).csv))

## Run p26 cache size many benchmarks
.PHONY: bench-p26-y-cs-many
bench-p26-y-cs-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_cs_many.$(fs).$(sim).csv))

## Run p26 cache size logging benchmarks
.PHONY: bench-p26-y-cs-logging
bench-p26-y-cs-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_cs_logging.$(fs).$(sim).csv))


# p26 cache size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - cache sizes
#
define BENCH_P26_T_Y_CS_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DCACHE_SIZE=$(or $5,$(P26_T_CACHE_SIZES)) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 cache size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_Y_CS_RULE,$\
				$(RESULTSDIR)/bench_p26_y_cs_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 cache size benchmarks
.PHONY: plot-p26-y-cs
plot-p26-y-cs: \
		plot-p26-y-cs-linear \
		plot-p26-y-cs-random \
		plot-p26-y-cs-many \
		plot-p26-y-cs-logging

## Plot p26 cache size linear benchmarks
.PHONY: plot-p26-y-cs-linear
plot-p26-y-cs-linear: \
		$(foreach sim, $(BENCH_SIMS), \
			$(PLOTSDIR)/bench_p26_y_cs_$(sim)_linear.svg)

## Plot p26 cache size random benchmarks
.PHONY: plot-p26-y-cs-random
plot-p26-y-cs-random: \
		$(foreach sim, $(BENCH_SIMS), \
			$(PLOTSDIR)/bench_p26_y_cs_$(sim)_random.svg)

## Plot p26 cache size many benchmarks
.PHONY: plot-p26-y-cs-many
plot-p26-y-cs-many: \
		$(foreach sim, $(BENCH_SIMS), \
			$(PLOTSDIR)/bench_p26_y_cs_$(sim)_many.svg)

## Plot p26 cache size logging benchmarks
.PHONY: plot-p26-y-cs-logging
plot-p26-y-cs-logging: \
		$(foreach sim, $(BENCH_SIMS), \
			$(PLOTSDIR)/bench_p26_y_cs_$(sim)_logging.svg)



# p26 cache sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_Y_CS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.5" \
		--subplot-right=" \
			--title='disk usage' \
			-Dm=usage \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 cache size plot rules
$(foreach sim, $(BENCH_SIMS), \
	$(eval $(call PLOT_P26_Y_CS_RULE,$\
			$(PLOTSDIR)/bench_p26_y_cs_$(sim)_%.svg,$\
			$(foreach fs, $(BENCH_FSS),$\
				$(RESULTSDIR)/bench_p26_y_cs_%.$(fs).$(sim).tsim.csv \
				$(RESULTSDIR)/bench_p26_y_cs_%.$(fs).$(sim).ram.csv \
				$(RESULTSDIR)/bench_p26_y_cs_%.$(fs).$(sim).csv),$\
			"cache sizes - $(sim) - $$* - simulated throughput",$\
			CACHE_SIZE,$\
			$(P26_T_CACHE_SIZES),$\
			--xlabel="cache size")))




## Generate cache size tikz results
.PHONY: tikz-p26-y-cs
tikz-p26-y-cs: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_cs_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_cs_ram_$(bench)$\
						.$(fs).$(sim).csv)))

# tikz cache size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_CS_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bCACHE_SIZE \
		-Si=CACHE_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_CS_RULE,$\
				$(TIKZDIR)/tikz_p26_y_cs_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_cs_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz cache size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_CS_RAM_RULE
$1: $(BENCH_$(U_$3)_RUNNER) $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=stack \
			-fdata="$$$$( \
				./scripts/data.py $$< -bfunction -o- \
					| $(BENCH_$(U_$3)_FILTER) \
					| ./scripts/csv.py - -fdata_size --total)" \
			-fstack=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=heap \
			-fheap=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bCACHE_SIZE \
		-Si=CACHE_SIZE \
		-fdata \
		-fstack \
		-fheap \
		-fram=data+stack+heap \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_CS_RAM_RULE,$\
				$(TIKZDIR)/tikz_p26_y_cs_ram_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_cs_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))


