# overrideable results dir
RESULTSDIR ?= results_1M
# overrideable plots dir
PLOTSDIR ?= plots_1M
# overrideable tikz dir
TIKZDIR ?= tikz_1M


# give us more space for activities
DISK_SIZE ?= 134217728 # 128 MiB

# increase bench sizes to 1 MiB
P26_LITMUS_SIZE ?= 1048576
ifdef PRECISE
P26_LITMUS_STEP ?= 32
else
P26_LITMUS_STEP ?= 256 # was 32, prioritizing speed over accuracy
endif

# 1KiB -> 1MiB
P26_T_SIZES ?= $\
	1024,2048,4096,8192,16384,32768,$\
		65536,131072,262144,524288,1048576

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif


# default Makefile does most of the work
include Makefile

