# overrideable results dir
RESULTSDIR ?= results_y_ss_mr
# overrideable plots dir
PLOTSDIR ?= plots_y_ss_mr
# overrideable tikz dir
TIKZDIR ?= tikz_y_ss_mr


# range of file sizes to test for throughput testing
P26_T_FILE_SIZES ?= $\
	8,16,32,$\
	64,128,256,512,$\
	1024,2048,4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576

# limit the affect of caching
P26_T_CACHE_SIZE ?= 64

# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
# DISK_SIZE ?= 134217728 # 128 MiB
# DISK_SIZE ?= 268435456 # 256 MiB
DISK_SIZE ?= 536870912 # 512 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# bench several configurations
BENCH_FSS ?= lfs3s0 $\
	lfs3s64 lfs3s128 lfs3s256 lfs3s512 lfs3s1024 lfs3s2048 $\
	lfs3s4096 lfs3s8192 lfs3s16384 lfs3s32768
# we've tuned things for NAND
BENCH_SIMS ?= nand

# extra config, note we don't bother with uppercasing
$(foreach fs,$(BENCH_FSS), \
	$(eval U_$(fs) = $(fs)) \
	$(eval N_$(fs) = $(fs:lfs3s%=%)) \
	$(eval I_$(fs) = $(fs:lfs3s%=%)) \
	$(eval C_$(fs) = \#da8bc3bf $(if ,# pink)) \
	$(eval F_$(fs) = x $(if ,# small)) \
	$(eval BENCH_$(fs)_RUNNER ?= $$(BENCH_LFS3_RUNNER)) \
	$(eval BENCH_$(fs)_FILTER ?= $$(BENCH_LFS3_FILTER)) \
	$(eval EMMC_$(fs)_BLOCK_SIZE ?= $$(EMMC_LFS3_BLOCK_SIZE)) \
	$(eval NOR_$(fs)_BLOCK_SIZE  ?= $$(NOR_LFS3_BLOCK_SIZE)) \
	$(eval NAND_$(fs)_BLOCK_SIZE ?= $$(NAND_LFS3_BLOCK_SIZE)))


# use our bench rules
BENCH_RULES ?= \
	bench-p26-y-ss-mr
# use our plot rules
PLOT_RULES ?= \
	plot-p26-y-ss-mr
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-y-ss-mr

# default Makefile does most of the work
include Makefile


## Run p26 shrub size benchmarks
.PHONY: bench-p26-y-ss-mr
bench-p26-y-ss-mr: \
		bench-p26-y-ss-mr-many

## Run p26 shrub size linear benchmarks
.PHONY: bench-p26-y-ss-mr-linear
bench-p26-y-ss-mr-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ss_mr_linear.$(fs).$(sim).csv))

## Run p26 shrub size random benchmarks
.PHONY: bench-p26-y-ss-mr-random
bench-p26-y-ss-mr-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ss_mr_random.$(fs).$(sim).csv))

## Run p26 shrub size many benchmarks
.PHONY: bench-p26-y-ss-mr-many
bench-p26-y-ss-mr-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ss_mr_many.$(fs).$(sim).csv))

## Run p26 shrub size logging benchmarks
.PHONY: bench-p26-y-ss-mr-logging
bench-p26-y-ss-mr-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ss_mr_logging.$(fs).$(sim).csv))


# p26 shrub size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
#
define BENCH_P26_T_Y_SS_MR_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DINLINE_SIZE=$(3:lfs3s%=%) \
		-DCACHE_SIZE=$(P26_T_CACHE_SIZE) \
		-DFILE_SIZE=$(P26_T_FILE_SIZES) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 shrub size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_Y_SS_MR_RULE,$\
				$(RESULTSDIR)/bench_p26_y_ss_mr_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



## Plot p26 shrub size benchmarks
.PHONY: plot-p26-y-ss-mr
plot-p26-y-ss-mr: \
		plot-p26-y-ss-mr-many

## Plot p26 shrub size linear benchmarks
.PHONY: plot-p26-y-ss-mr-linear
plot-p26-y-ss-mr-linear: \
		$(PLOTSDIR)/bench_p26_y_ss_mr_linear.svg

## Plot p26 shrub size random benchmarks
.PHONY: plot-p26-y-ss-mr-random
plot-p26-y-ss-mr-random: \
		$(PLOTSDIR)/bench_p26_y_ss_mr_random.svg

## Plot p26 shrub size many benchmarks
.PHONY: plot-p26-y-ss-mr-many
plot-p26-y-ss-mr-many: \
		$(PLOTSDIR)/bench_p26_y_ss_mr_many.svg

## Plot p26 shrub size logging benchmarks
.PHONY: plot-p26-y-ss-mr-logging
plot-p26-y-ss-mr-logging: \
		$(PLOTSDIR)/bench_p26_y_ss_mr_logging.svg



# p26 shrub sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_Y_SS_MR_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.5" \
		--subplot-right=" \
			--title='disk usage' \
			-Dm=usage \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		-F1- -F2- -F3- -F4- \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5][::3]: $\
				print("--add-xticklabel=%d=\"%%(x)IB%%n(%d)\"" % ($\
					n, $(P26_T_SIZE)/n))') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 shrub size plot rules
$(eval $(call PLOT_P26_Y_SS_MR_RULE,$\
		$(PLOTSDIR)/bench_p26_y_ss_mr_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_y_ss_mr_%.$(fs).nand.tsim.csv \
			$(RESULTSDIR)/bench_p26_y_ss_mr_%.$(fs).nand.ram.csv \
			$(RESULTSDIR)/bench_p26_y_ss_mr_%.$(fs).nand.csv),$\
		"shrub sizes - NAND - $$* - simulated throughput",$\
		FILE_SIZE,$\
		$(P26_T_FILE_SIZES)))




## Generate shrub size tikz results
.PHONY: tikz-p26-y-ss-mr
tikz-p26-y-ss-mr: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach bench, many, \
				$(TIKZDIR)/tikz_p26_y_ss_mr_$(bench).$(fs).nand.csv)) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach bench, many, \
				$(TIKZDIR)/tikz_p26_y_ss_mr_usage_$(bench).$(fs).nand.csv))

# tikz shrub size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_SS_MR_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bFILE_SIZE \
		-Si=FILE_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, many, \
			$(eval $(call TIKZ_T_Y_SS_MR_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ss_mr_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_ss_mr_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz shrub size disk usage rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_SS_MR_USAGE_RULE
$1: $2
	$$(strip ./scripts/csv.py $$^ \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bFILE_SIZE \
		-Si=FILE_SIZE \
		-Dm=usage \
		-fusage=bench_readed \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, many, \
			$(eval $(call TIKZ_T_Y_SS_MR_USAGE_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ss_mr_usage_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_ss_mr_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

