# overrideable results dir
RESULTSDIR ?= results_poster
# overrideable plots dir
PLOTSDIR ?= plots_poster
# overrideable tikz dir
TIKZDIR ?= tikz_poster


# give us more space for activities
DISK_SIZE ?= 134217728 # 128 MiB

# how many entries to test?
#BENCH_RBYD_N ?= 4096
BENCH_RBYD_N ?= 8192
#BENCH_BTREE_N ?= 4096
BENCH_BTREE_N ?= 8192
# how big a file to simulate?
#BENCH_WT_SIZE ?= 1048576 # 1 MiB
BENCH_WT_SIZE ?= 2097152 # 2 MiB
#BENCH_WT_SIZE ?= 16777216 # 16 MiB
# how big a chunk to write?
BENCH_WT_CHUNK ?= 64

# block sizes for btree benchmarks
BENCH_BTREE_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576
# block sizes for write-throughput benchmarks
BENCH_WT_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072,$\
	262144,524288,1048576

# how many samples?
ifdef PRECISE
SAMPLES ?= 1 # 16 uses too much memory, and doesn't really add much
else
SAMPLES ?= 1
endif
# how long to simulate?
ifdef PRECISE
SIM_TIME ?= 3600000000000 # 1 hour
else
SIM_TIME ?= 600000000000 # 10 minutes
endif

# we only care about littlefs3+nogbmap, +fragmented, and littlefs2
BENCH_FSS ?= lfs3nb lfs3nbf lfs3nb128 lfs3nb64 lfs3nb32 lfs3nb8 lfs3nb2 lfs2
# stick to a simple simulation for now
BENCH_SIM ?= nor
BENCH_SIMPLE ?= 1

# enable debug to make sure benches work, otherwise asserts are disabled
#DEBUG ?= 1

# stride of results to filter during tikz processing
COMB ?= 16


# extra lfs3nbf config
U_lfs3nbf = LFS3NBF
N_lfs3nbf = 31
I_lfs3nbf = 6
ifdef LIGHT
C_lfs3nbf = \#da8bc3bf # pink
else
C_lfs3nbf = \#da8bc3bf # pink
endif
F_lfs3nbf = x # small x
BENCH_LFS3NBF_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NBF_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb128 = LFS3NB128
N_lfs3nb128 = 32
I_lfs3nb128 = 7
ifdef LIGHT
C_lfs3nb128 = \#8172b3bf # purple
else
C_lfs3nb128 = \#d0bbffbf # purple
endif
F_lfs3nb128 = 2 # small tri up
BENCH_LFS3NB128_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB128_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb64 = LFS3NB64
N_lfs3nb64 = 33
I_lfs3nb64 = 8
ifdef LIGHT
C_lfs3nb64 = \#8172b3bf # purple
else
C_lfs3nb64 = \#d0bbffbf # purple
endif
F_lfs3nb64 = 2 # small tri up
BENCH_LFS3NB64_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB64_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb32 = LFS3NB32
N_lfs3nb32 = 34
I_lfs3nb32 = 9
ifdef LIGHT
C_lfs3nb32 = \#8172b3bf # purple
else
C_lfs3nb32 = \#d0bbffbf # purple
endif
F_lfs3nb32 = 2 # small tri up
BENCH_LFS3NB32_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB32_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb16 = LFS3NB16
N_lfs3nb16 = 35
I_lfs3nb16 = 10
ifdef LIGHT
C_lfs3nb16 = \#8172b3bf # purple
else
C_lfs3nb16 = \#d0bbffbf # purple
endif
F_lfs3nb16 = 1 # small tri down
BENCH_LFS3NB16_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB16_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb8 = LFS3NB8
N_lfs3nb8 = 36
I_lfs3nb8 = 11
ifdef LIGHT
C_lfs3nb8 = \#8172b3bf # purple
else
C_lfs3nb8 = \#d0bbffbf # purple
endif
F_lfs3nb8 = 1 # small tri down
BENCH_LFS3NB8_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB8_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb4 = LFS3NB4
N_lfs3nb4 = 37
I_lfs3nb4 = 12
ifdef LIGHT
C_lfs3nb4 = \#8172b3bf # purple
else
C_lfs3nb4 = \#d0bbffbf # purple
endif
F_lfs3nb4 = 1 # small tri down
BENCH_LFS3NB4_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB4_FILTER ?= $(BENCH_LFS3NB_FILTER)

U_lfs3nb2 = LFS3NB2
N_lfs3nb2 = 38
I_lfs3nb2 = 13
ifdef LIGHT
C_lfs3nb2 = \#8172b3bf # purple
else
C_lfs3nb2 = \#d0bbffbf # purple
endif
F_lfs3nb2 = 1 # small tri down
BENCH_LFS3NB2_RUNNER ?= $(BENCH_LFS3NB_RUNNER)
BENCH_LFS3NB2_FILTER ?= $(BENCH_LFS3NB_FILTER)


# override bench rules
BENCH_RULES ?= \
	bench-p26-poster-rbyd \
	bench-p26-poster-btree \
	bench-p26-poster-wt
# override plot rules
PLOT_RULES ?= \
	plot-p26-poster-rbyd \
	plot-p26-poster-btree \
	plot-p26-poster-wt
# override tikz rules
TIKZ_RULES ?= \
	tikz-p26-poster-rbyd \
	tikz-p26-poster-btree \
	tikz-p26-poster-wt

# default Makefile does most of the work
include Makefile


## Run rbyd benchmarks
.PHONY: bench-p26-poster-rbyd
bench-p26-poster-rbyd: $(RESULTSDIR)/bench_p26_poster_rbyd.csv

$(RESULTSDIR)/bench_p26_poster_rbyd.csv: $(BENCH_LFS3NB_RUNNER)
	$(strip ./scripts/bench.py -R$< -B bench_p26_rbyd \
		$(BENCHFLAGS) \
		-DFS=$(N_lfs3) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DDISK_GEOMETRY=$(N_$(BENCH_SIM)) \
		$(if $(BENCH_SIMPLE),-DDISK_SIM=1) \
		-DSEED="range($(SAMPLES))" \
		-DN=$(BENCH_RBYD_N) \
		-x1 \
		-o$@)

## Run btree benchmarks
.PHONY: bench-p26-poster-btree
bench-p26-poster-btree: $(RESULTSDIR)/bench_p26_poster_btree.csv

$(RESULTSDIR)/bench_p26_poster_btree.csv: $(BENCH_LFS3NB_RUNNER)
	$(strip ./scripts/bench.py -R$< -B bench_p26_btree \
		$(BENCHFLAGS) \
		-DFS=$(N_lfs3) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DDISK_GEOMETRY=$(N_$(BENCH_SIM)) \
		$(if $(BENCH_SIMPLE),-DDISK_SIM=1) \
		-DSEED="range($(SAMPLES))" \
		-DN=$(BENCH_BTREE_N) \
		-DORDER=2 \
		-DBLOCK_SIZE="$(BENCH_BTREE_BLOCK_SIZES)" \
		-x1 \
		-o$@)

## Run write-throughput benchmarks
.PHONY: bench-p26-poster-wt
bench-p26-poster-wt: \
		$(foreach fs,$(BENCH_FSS),\
			$(RESULTSDIR)/bench_p26_poster_wt.$(fs).csv)

# $1 - target
# $2 - fs type/version
# $3 - block sizes
define BENCH_P26_POSTER_WT_RULE
$1: $(BENCH_$(U_$2)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B \
		bench_p26_wt_linear \
		bench_p26_wt_random \
		bench_p26_wt_logging \
		$(BENCHFLAGS) \
		-DFS=$(N_$2) \
		$(if $(filter lfs3nbf,$2),-DCRYSTAL_THRESH=-1) \
		$(if $(filter lfs3nb128,$2),-DCRYSTAL_DIV=128) \
		$(if $(filter lfs3nb64,$2),-DCRYSTAL_DIV=64) \
		$(if $(filter lfs3nb32,$2),-DCRYSTAL_DIV=32) \
		$(if $(filter lfs3nb16,$2),-DCRYSTAL_DIV=16) \
		$(if $(filter lfs3nb8,$2),-DCRYSTAL_DIV=8) \
		$(if $(filter lfs3nb4,$2),-DCRYSTAL_DIV=4) \
		$(if $(filter lfs3nb2,$2),-DCRYSTAL_DIV=2) \
		-DDISK_SIZE=$(DISK_SIZE) \
		-DDISK_GEOMETRY=$(N_$(BENCH_SIM)) \
		$(if $(BENCH_SIMPLE),-DDISK_SIM=1) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(BENCH_WT_SIZE) \
		-DCHUNK=$(BENCH_WT_CHUNK) \
		-DSIM_TIME=$(SIM_TIME) \
		-DBLOCK_SIZE="$(or $3,$(BENCH_WT_BLOCK_SIZES))" \
		-o$$@)
endef

$(foreach fs,$(BENCH_FSS),$\
	$(eval $(call BENCH_P26_POSTER_WT_RULE,$\
		$(RESULTSDIR)/bench_p26_poster_wt.$(fs).csv,$\
		$(fs))))


## Plot rbyd benchmarks
.PHONY: plot-p26-poster-rbyd
plot-p26-poster-rbyd: $(PLOTSDIR)/bench_p26_poster_rbyd.svg

$(PLOTSDIR)/bench_p26_poster_rbyd.csv: \
		$(RESULTSDIR)/bench_p26_poster_rbyd.csv
	$(strip ./scripts/csv.py \
		<(./scripts/csv.py $^ \
			-Dprobe=create,delete,lookup \
			-bprobe -bORDER -bn -bSEED \
			-fbench_simtime='float(delta( \
					probe, ORDER, SEED; \
					bench_simtime)) \
				/1.0e9' \
			-o-) \
		<(./scripts/csv.py $^ \
			-Dprobe=fetch \
			-bprobe='%(probe)s+per' -bORDER -bn -bSEED \
			-fbench_simtime='float(delta( \
					probe, ORDER, SEED; \
					bench_simtime)) \
				/1.0e9/float(n)' \
			-o-) \
		<(./scripts/csv.py $^ \
			-Dprobe=usage \
			-bprobe='%(probe)s+per' -bORDER -bn -bSEED \
			-fbench_simtime='float(bench_simtime)/float(n)' \
			-o-) \
		-fbench_simtime \
		-o$@)

$(PLOTSDIR)/bench_p26_poster_rbyd.avg.csv: \
		$(PLOTSDIR)/bench_p26_poster_rbyd.csv
	$(strip ./scripts/csv.py $^ \
		-DSEED='*' \
		-fbench_simtime_avg='avg(bench_simtime)' \
		-fbench_simtime_min='min(bench_simtime)' \
		-fbench_simtime_max='max(bench_simtime)' \
		-o$@)

$(PLOTSDIR)/bench_p26_poster_rbyd.svg: \
		$(PLOTSDIR)/bench_p26_poster_rbyd.avg.csv
	$(strip ./scripts/plotmpl.py \
		<(./scripts/csv.py $^ \
			-fbench_simtime_avg \
			-fbench_simtime_bnd=bench_simtime_max \
			-o-) \
		<(./scripts/csv.py $^ \
			-Dbench_simtime_avg='*' \
			-fbench_simtime_bnd=bench_simtime_min \
			-o-) \
		-W1500 -H350 \
		--title='rbyd operations' \
		-bORDER \
		-xn \
		-ybench_simtime_avg \
		-ybench_simtime_bnd \
		--yunits=s \
		--legend \
		-L0,bench_simtime_avg=inorder \
		-L1,bench_simtime_avg=reversed \
		-L2,bench_simtime_avg=random \
		-L0,bench_simtime_bnd= \
		-L1,bench_simtime_bnd= \
		-L2,bench_simtime_bnd= \
		-C0,bench_simtime_avg=$(C_lfs3) \
		-C1,bench_simtime_avg=$(C_lfs3nb) \
		-C2,bench_simtime_avg=$(C_lfs2) \
		-C0,bench_simtime_bnd=$(C_lfs3:bf=1f) \
		-C1,bench_simtime_bnd=$(C_lfs3nb:bf=1f) \
		-C2,bench_simtime_bnd=$(C_lfs2:bf=1f) \
		--subplot=" \
			-Dprobe=create \
			--title='create'" \
		--subplot-right=" \
			-Dprobe=delete \
			--title='delete' \
			-W0.5" \
		--subplot-right=" \
			-Dprobe=fetch+per \
			--title='fetch (per attr)' \
			-W0.33" \
		--subplot-right=" \
			-Dprobe=lookup \
			--title='lookup' \
			-W0.25" \
		--subplot-right=" \
			-Dprobe=usage+per \
			--title='usage (per attr)' \
			--y2 --yunits=B \
			-W0.2" \
		$(PLOTFLAGS) \
		-o$@)

