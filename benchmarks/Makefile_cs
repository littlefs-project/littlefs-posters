# p26 cache sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - measurement
# $5 - extra plotmpl.py flags
#
define PLOT_P26_CS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-xCACHE_SIZE \
		-ybench_readed \
		-Dm=$4 \
		--subplot=" \
			-DERASE_SIZE=$(NOR_ERASE_SIZE) \
			--title=nor \
			-X"$$(shell python -c '$\
					a=min([$(P26_T_NOR_CACHE_SIZES)]);$\
					print(a-a/4)'),$\
				$$(shell python -c '$\
					b=max([$(P26_T_NOR_CACHE_SIZES)]);$\
					print(b+b/4)')" \
			$$(shell python -c '$\
				for n in [$(P26_T_NOR_CACHE_SIZES)]: $\
					print("--add-xticklabel=%d=\\\"%%(x)IB\\\"" % n)')" \
		--subplot-right=" \
			-DERASE_SIZE=$(NAND_ERASE_SIZE) \
			--title=nand \
			-X"$$(shell python -c '$\
					a=min([$(P26_T_NAND_CACHE_SIZES)]);$\
					print(a-a/4)'),$\
				$$(shell python -c '$\
					b=max([$(P26_T_NAND_CACHE_SIZES)]);$\
					print(b+b/4)')" \
			$$(shell python -c '$\
				for n in [$(P26_T_NAND_CACHE_SIZES)]: $\
					print("--add-xticklabel=%d=\\\"%%(x)IB\\\"" % n)') \
			-W0.5" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		--x2 --xunits=B \
		$5 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 cache size plot rules
$(eval $(call PLOT_P26_CS_RULE,$\
		$(PLOTSDIR)/bench_p26_cs_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
				$(RESULTSDIR)/bench_p26_cs_%.$(fs).$(sim).tsim.csv)),$\
		"$$* file writes - cache sizes - simulated throughput",$\
		write+tsim,$\
		--xlabel="cache size" --y2 --yunits=B/s))

$(eval $(call PLOT_P26_CS_RULE,$\
