# overrideable results dir
RESULTSDIR ?= results_y_ls
# overrideable plots dir
PLOTSDIR ?= plots_y_ls
# overrideable tikz dir
TIKZDIR ?= tikz_y_ls


# range of erase sizes to test for throughput testing
# note 1024 = 128MiB/128KiB (NAND)
# note 32768 = 128MiB/4KiB (NOR)
P26_T_LOOKAHEAD_SIZES ?= 1,2,4,8,16,32,64,128,256,512,1024
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# this only makes sense for littlefs3
BENCH_FSS ?= lfs3 lfs3nb lfs2
# we mostly care about NAND, but NOR has higher block counts
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-y-ls
# use our plot rules
PLOT_RULES ?= \
	plot-p26-y-ls
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-y-ls

# default Makefile does most of the work
include Makefile



## Run p26 lookahead size benchmarks
.PHONY: bench-p26-y-ls
bench-p26-y-ls: \
		bench-p26-y-ls-linear \
		bench-p26-y-ls-random \
		bench-p26-y-ls-many \
		bench-p26-y-ls-logging

## Run p26 lookahead size linear benchmarks
.PHONY: bench-p26-y-ls-linear
bench-p26-y-ls-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ls_linear.$(fs).$(sim).csv))

## Run p26 lookahead size random benchmarks
.PHONY: bench-p26-y-ls-random
bench-p26-y-ls-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ls_random.$(fs).$(sim).csv))

## Run p26 lookahead size many benchmarks
.PHONY: bench-p26-y-ls-many
bench-p26-y-ls-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ls_many.$(fs).$(sim).csv))

## Run p26 lookahead size logging benchmarks
.PHONY: bench-p26-y-ls-logging
bench-p26-y-ls-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ls_logging.$(fs).$(sim).csv))


# p26 lookahead size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - lookahead sizees
#
define BENCH_P26_T_Y_LS_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DLOOKAHEAD_SIZE=$(or $5,$(P26_T_LOOKAHEAD_SIZES)) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 lookahead size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_Y_LS_RULE,$\
				$(RESULTSDIR)/bench_p26_y_ls_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



