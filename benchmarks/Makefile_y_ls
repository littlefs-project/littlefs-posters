# p26 lookahead sizes plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_Y_LS_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.5" \
		--subplot-right=" \
			--title='disk usage' \
			-Dm=usage \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 lookahead size plot rules
$(foreach sim, $(BENCH_SIMS), \
	$(eval $(call PLOT_P26_Y_LS_RULE,$\
			$(PLOTSDIR)/bench_p26_y_ls_$(sim)_%.svg,$\
			$(foreach fs, $(BENCH_FSS),$\
				$(RESULTSDIR)/bench_p26_y_ls_%.$(fs).$(sim).tsim.csv \
				$(RESULTSDIR)/bench_p26_y_ls_%.$(fs).$(sim).ram.csv \
				$(RESULTSDIR)/bench_p26_y_ls_%.$(fs).$(sim).csv),$\
			"lookahead sizes - $(sim) - $$* - simulated throughput",$\
			LOOKAHEAD_SIZE,$\
			$(P26_T_LOOKAHEAD_SIZES),$\
			--xlabel="lookahead size")))




## Generate lookahead size tikz results
.PHONY: tikz-p26-y-ls
tikz-p26-y-ls: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_ls_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_ls_ram_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_ls_l16_$(bench)$\
						.$(fs).$(sim).csv))) \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(foreach bench, linear random many logging, \
					$(TIKZDIR)/tikz_p26_y_ls_ram_l16_$(bench)$\
						.$(fs).$(sim).csv)))

# tikz lookahead size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_LS_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bLOOKAHEAD_SIZE \
		-Si=LOOKAHEAD_SIZE \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_LS_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ls_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_ls_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz lookahead size rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_LS_RAM_RULE
$1: $(BENCH_$(U_$3)_RUNNER) $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=stack \
			-fdata="$$$$( \
				./scripts/data.py $$< -bfunction -o- \
					| $(BENCH_$(U_$3)_FILTER) \
					| ./scripts/csv.py - -fdata_size --total)" \
			-fstack=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		<(./scripts/csv.py $$(wordlist 2,$$(words $$^),$$^) \
			-Dm=heap \
			-fheap=bench_readed \
			-Dn='*' \
			-Dbench_readed='*' \
			-Dbench_proged='*' \
			-Dbench_erased='*' \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-bLOOKAHEAD_SIZE \
		-Si=LOOKAHEAD_SIZE \
		-fdata \
		-fstack \
		-fheap \
		-fram=data+stack+heap \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_LS_RAM_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ls_ram_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_ls_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))


# tikz lookahead size fixed l=16B rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_LS_L16_RULE
$1: $2
	$$(strip ./scripts/csv.py $$^ \
		-bLOOKAHEAD_SIZE \
		-Si=LOOKAHEAD_SIZE \
		-fthroughput="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fthroughput --total)" \
		-fn="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fn --total)" \
		-ft="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -ft --total)" \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_LS_L16_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ls_l16_$(bench).$(fs).$(sim).csv,$\
				$(TIKZDIR)/tikz_p26_y_ls_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

# tikz lookahead size fixed l=16B rule
