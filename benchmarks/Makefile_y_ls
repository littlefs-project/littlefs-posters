		-Si=LOOKAHEAD_SIZE \
		-fdata="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fdata --total)" \
		-fstack="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fstack --total)" \
		-fheap="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fheap --total)" \
		-fram="$$$$(./scripts/csv.py $$^ \
			-DLOOKAHEAD_SIZE=16 -fram --total)" \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_LS_RAM_L16_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ls_ram_l16_$(bench).$(fs).$(sim).csv,$\
				$(TIKZDIR)/tikz_p26_y_ls_ram_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

