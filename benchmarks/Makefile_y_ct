# p26 crystal threshs plot rule
#
# $1 - target
# $2 - sources
# $3 - title
# $4 - x-axis
# $5 - x-ticks
# $6 - extra plotmpl.py flags
#
define PLOT_P26_Y_CT_RULE
$1: $2
	$$(strip ./scripts/plotmpl.py $$^ \
		-W1500 -H350 \
		--title=$3 \
		-bFS \
		-x$4 \
		-ybench_readed \
		--subplot=" \
			--title='simulated throughput' \
			-Dm=write+tsim \
 			--y2 --yunits=B/s" \
		--subplot-right=" \
			--title='ram usage' \
			-Dm=ram \
 			--y2 --yunits=B \
			-W0.5" \
		--subplot-right=" \
			--title='disk usage' \
			-Dm=usage \
 			--y2 --yunits=B \
			-W0.33" \
		--legend \
		$(foreach fs, $(BENCH_FSS),$\
			-L'$(N_$(fs))=$(fs)') \
		$(foreach fs, $(BENCH_FSS),$\
			-C'$(N_$(fs))=$(C_$(fs))') \
		$(foreach fs, $(BENCH_FSS),$\
			-F'$(N_$(fs))=$(addsuffix -,$(F_$(fs)))') \
		--xlog \
		--xticks=4 \
		-X"$$(shell python -c 'a=min([$5]); print(a-a/4)'),$\
			$$(shell python -c 'b=max([$5]); print(b+b/4)')" \
		--x2 --xunits=B \
		$$(shell python -c '$\
			for n in [$5][::2]: $\
				print("--add-xticklabel=%d=\"%%(x)IB\"" % n)') \
		$6 \
		$$(PLOTFLAGS) \
		-o$$@)
endef

# p26 crystal thresh plot rules
$(eval $(call PLOT_P26_Y_CT_RULE,$\
		$(PLOTSDIR)/bench_p26_y_ct_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(RESULTSDIR)/bench_p26_y_ct_%.$(fs).nand.tsim.csv \
			$(RESULTSDIR)/bench_p26_y_ct_%.$(fs).nand.ram.csv \
			$(RESULTSDIR)/bench_p26_y_ct_%.$(fs).nand.csv),$\
		"crystal threshs - NAND - $$* - simulated throughput",$\
		CRYSTAL_THRESH,$\
		$(P26_T_CRYSTAL_THRESHS),$\
		--xlabel="crystal thresh"))




## Generate crystal thresh tikz results
.PHONY: tikz-p26-y-ct
tikz-p26-y-ct: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach bench, linear random many logging, \
				$(TIKZDIR)/tikz_p26_y_ct_$(bench).$(fs).nand.csv))

# tikz crystal thresh rule
#
# $1 - target
# $2 - source
# $3 - fs type/version
# $4 - sim
# $5 - bench
#
define TIKZ_T_Y_CT_RULE
$1: $2
	$$(strip ./scripts/csv.py \
		<(./scripts/csv.py $$^ \
			-fn \
			-fbench_readed \
			-fbench_proged \
			-fbench_erased \
			-Dbench_creaded='*' \
			-Dbench_cproged='*' \
			-Dbench_cerased='*' \
			-o-) \
		-bfs=$3 \
		-bsim=$4 \
		-bbench=$5 \
		-Dm=write,read \
		-bCRYSTAL_THRESH \
		-Si=CRYSTAL_THRESH \
		-fthroughput=' \
			float(n) / max( \
				(float(bench_readed)*float(READ_TIME) \
					+ float(bench_proged)*float(PROG_TIME) \
					+ float(bench_erased)*float(ERASE_TIME) \
					) / 1.0e9, \
				1.0e-9)' \
		-fn \
		-ft=' \
			(float(bench_readed)*float(READ_TIME) \
				+ float(bench_proged)*float(PROG_TIME) \
				+ float(bench_erased)*float(ERASE_TIME) \
			) / 1.0e9' \
		-o$$@)
endef

$(foreach fs, $(BENCH_FSS), \
	$(foreach sim, $(BENCH_SIMS), \
		$(foreach bench, linear random many logging, \
			$(eval $(call TIKZ_T_Y_CT_RULE,$\
				$(TIKZDIR)/tikz_p26_y_ct_$(bench).$(fs).$(sim).csv,$\
				$(RESULTSDIR)/bench_p26_y_ct_$(bench).$(fs).$(sim).csv,$\
				$(fs),$\
				$(sim),$\
				$(bench))))))

