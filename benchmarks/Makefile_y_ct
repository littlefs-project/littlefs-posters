# overrideable results dir
RESULTSDIR ?= results_y_ct
# overrideable plots dir
PLOTSDIR ?= plots_y_ct
# overrideable tikz dir
TIKZDIR ?= tikz_y_ct


# range of erase sizes to test for throughput testing
P26_T_CRYSTAL_THRESHS ?= 1,4,8,16,32,64,128,256,$\
		512,1024,2048,4096,8192,16384,32768,65536,131072,$\
		262144
# some other tweaks
P26_T_SIZE ?= 1048576 # 1 MiB
DISK_SIZE ?= 134217728 # 128 MiB

# increase simtime for more reliable results
ifdef PRECISE
P26_T_SIM_TIME ?= 3600000000000 # 1 hour
else
P26_T_SIM_TIME ?= 600000000000 # 10 minutes
endif

# this only makes sense for littlefs3
BENCH_FSS ?= lfs3 lfs3nb
# we only care about NAND here
BENCH_SIMS ?= nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-y-ct
# use our plot rules
PLOT_RULES ?= \
	plot-p26-y-ct
# use our tikz rules
TIKZ_RULES ?= \
	tikz-p26-y-ct

# default Makefile does most of the work
include Makefile



## Run p26 crystal thresh benchmarks
.PHONY: bench-p26-y-ct
bench-p26-y-ct: \
		bench-p26-y-ct-linear \
		bench-p26-y-ct-random \
		bench-p26-y-ct-many \
		bench-p26-y-ct-logging

## Run p26 crystal thresh linear benchmarks
.PHONY: bench-p26-y-ct-linear
bench-p26-y-ct-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ct_linear.$(fs).$(sim).csv))

## Run p26 crystal thresh random benchmarks
.PHONY: bench-p26-y-ct-random
bench-p26-y-ct-random: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ct_random.$(fs).$(sim).csv))

## Run p26 crystal thresh many benchmarks
.PHONY: bench-p26-y-ct-many
bench-p26-y-ct-many: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ct_many.$(fs).$(sim).csv))

## Run p26 crystal thresh logging benchmarks
.PHONY: bench-p26-y-ct-logging
bench-p26-y-ct-logging: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_y_ct_logging.$(fs).$(sim).csv))


# p26 crystal thresh bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - crystal threshes
#
define BENCH_P26_T_Y_CT_RULE
ifndef NO_BENCH
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(DISK_SIZE) \
		$(if $(SKIP_WARMUP),-DSKIP_WARMUP=$(SKIP_WARMUP)) \
		-DSIZE=$(P26_T_SIZE) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIM_TIME=$(or $(P26_T_SIM_TIME),0) \
		-DSIM_SIZE=$(or $(P26_T_SIM_SIZE),0) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DCRYSTAL_THRESH=$(or $5,$(P26_T_CRYSTAL_THRESHS)) \
		-o$$@)
else
$1:
	$$(warning NO_BENCH $$@)
endif
endef

# p26 crystal thresh bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_Y_CT_RULE,$\
				$(RESULTSDIR)/bench_p26_y_ct_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



