# overrideable results dir
RESULTSDIR ?= results_ps
# overrideable plots dir
PLOTSDIR ?= plots_ps


# range of read/prog sizes to test for throughput testing
P26_T_PAGE_SIZES ?= 1,4,8,16,32,64,128,256,512,1024,2048


# we only care about NOR and NAND really
BENCH_SIMS ?= nor nand

# use our bench rules
BENCH_RULES ?= \
	bench-p26-ps
# use our plot rules
PLOT_RULES ?= \
	plot-p26-ps

# default Makefile does most of the work
include Makefile



## Run p26 read/prog size benchmarks
.PHONY: bench-p26-ps
bench-p26-ps: \
		bench-p26-ps-linear \
		bench-p26-ps-random \
		bench-p26-ps-many \
		bench-p26-ps-logging

## Run p26 read/prog size linear benchmarks
.PHONY: bench-p26-ps-linear
bench-p26-ps-linear: \
		$(foreach fs, $(BENCH_FSS), \
			$(foreach sim, $(BENCH_SIMS), \
				$(RESULTSDIR)/bench_p26_ps_linear.$(fs).$(sim).csv))

## Run p26 read/prog size random benchmarks
