		DISK_SIZE,$\
		$(P26_T_DISK_SIZES),$\
		usage,$\
		--xlabel="disk size" --y2 --yunits=B))

$(eval $(call PLOT_P26_DS_RULE,$\
		$(PLOTSDIR)/bench_p26_ds_ram_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
